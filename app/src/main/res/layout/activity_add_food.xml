<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0B">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="‹"
            android:textSize="20sp"
            android:background="@android:color/transparent"
            android:textColor="#9A9AA3"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LOG FOOD"
            android:textSize="14sp"
            android:textColor="#F4F4F6"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:paddingStart="8dp"/>
    </LinearLayout>

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#141419"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌕"
            android:textSize="18sp"
            android:textColor="#5C5C66"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:hint="Search foods…"
            android:hintTextColor="#5C5C66"
            android:textColor="#F4F4F6"
            android:textSize="14sp"
            android:background="@android:color/transparent"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true"/>
    </LinearLayout>

    <!-- Meal type chips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <Button android:id="@+id/btnBreakfast"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="Breakfast" android:textSize="11sp" android:textColor="#A100FF"
            android:background="@drawable/bg_chip_active"
            android:layout_marginEnd="3dp"
            android:minWidth="0dp" android:minHeight="0dp"/>

        <Button android:id="@+id/btnLunch"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="Lunch" android:textSize="11sp" android:textColor="#9A9AA3"
            android:background="@drawable/bg_chip_inactive"
            android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:minWidth="0dp" android:minHeight="0dp"/>

        <Button android:id="@+id/btnDinner"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="Dinner" android:textSize="11sp" android:textColor="#9A9AA3"
            android:background="@drawable/bg_chip_inactive"
            android:layout_marginStart="3dp" android:layout_marginEnd="3dp"
            android:minWidth="0dp" android:minHeight="0dp"/>

        <Button android:id="@+id/btnSnack"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="Snack" android:textSize="11sp" android:textColor="#9A9AA3"
            android:background="@drawable/bg_chip_inactive"
            android:layout_marginStart="3dp"
            android:minWidth="0dp" android:minHeight="0dp"/>
    </LinearLayout>

    <!-- Results list -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/llSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

            <!-- Manual entry section -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#17FFFFFF"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MANUAL ENTRY"
                android:textSize="9sp"
                android:textColor="#5C5C66"
                android:letterSpacing="0.14"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:id="@+id/llManualSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp">

                <EditText android:id="@+id/etManualName"
                    android:layout_width="match_parent" android:layout_height="46dp"
                    android:hint="Food name" android:hintTextColor="#5C5C66"
                    android:textColor="#F4F4F6" android:textSize="14sp"
                    android:background="@drawable/bg_edittext"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText android:id="@+id/etManualCal"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:hint="kcal" android:hintTextColor="#5C5C66"
                        android:textColor="#F4F4F6" android:textSize="14sp"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:inputType="number" android:layout_marginEnd="4dp"/>

                    <EditText android:id="@+id/etManualProtein"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:hint="P(g)" android:hintTextColor="#5C5C66"
                        android:textColor="#F4F4F6" android:textSize="14sp"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:inputType="numberDecimal" android:layout_marginEnd="4dp"/>

                    <EditText android:id="@+id/etManualCarbs"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:hint="C(g)" android:hintTextColor="#5C5C66"
                        android:textColor="#F4F4F6" android:textSize="14sp"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:inputType="numberDecimal" android:layout_marginEnd="4dp"/>

                    <EditText android:id="@+id/etManualFat"
                        android:layout_width="0dp" android:layout_height="46dp" android:layout_weight="1"
                        android:hint="F(g)" android:hintTextColor="#5C5C66"
                        android:textColor="#F4F4F6" android:textSize="14sp"
                        android:background="@drawable/bg_edittext"
                        android:paddingStart="12dp" android:paddingEnd="12dp"
                        android:inputType="numberDecimal"/>
                </LinearLayout>

                <Button android:id="@+id/btnAddManual"
                    android:layout_width="match_parent" android:layout_height="44dp"
                    android:text="ADD MANUAL ENTRY" android:textSize="12sp"
                    android:textColor="#A100FF" android:letterSpacing="0.06"
                    android:background="@drawable/bg_chip_inactive"
                    android:layout_marginTop="8dp"
                    android:minWidth="0dp" android:minHeight="0dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Selected food panel -->
    <LinearLayout
        android:id="@+id/llSelectedCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#141419"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/tvSelFoodName"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Selected Food" android:textSize="15sp"
                    android:textColor="#F4F4F6" android:textStyle="bold"/>
                <TextView android:id="@+id/tvSelMacro"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="P 0g  C 0g  F 0g" android:textSize="11sp"
                    android:textColor="#5C5C66" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <TextView android:id="@+id/tvSelCal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 kcal" android:textSize="18sp"
                android:textColor="#C86BFF" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Serving stepper -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SERVINGS" android:textSize="9sp" android:textColor="#5C5C66"
                android:letterSpacing="0.1" android:layout_marginEnd="12dp"/>

            <Button android:id="@+id/btnServingMinus"
                android:layout_width="32dp" android:layout_height="32dp"
                android:text="−" android:textSize="18sp"
                android:background="@drawable/bg_chip_inactive"
                android:textColor="#9A9AA3"
                android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>

            <TextView android:id="@+id/tvServing"
                android:layout_width="36dp" android:layout_height="wrap_content"
                android:text="1" android:gravity="center"
                android:textSize="16sp" android:textColor="#F4F4F6" android:textStyle="bold"/>

            <Button android:id="@+id/btnServingPlus"
                android:layout_width="32dp" android:layout_height="32dp"
                android:text="+" android:textSize="18sp"
                android:background="@drawable/bg_chip_inactive"
                android:textColor="#A100FF"
                android:padding="0dp" android:minWidth="0dp" android:minHeight="0dp"/>
        </LinearLayout>

        <Button android:id="@+id/btnAddToLog"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="LOG THIS FOOD" android:textSize="13sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.06"
            android:background="#A100FF"
            android:minWidth="0dp" android:minHeight="0dp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#17FFFFFF"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0A0A0B"
        app:menu="@menu/bottom_nav"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"/>

</LinearLayout>
