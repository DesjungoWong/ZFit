<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101013">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#0A0A0B"
            android:padding="16dp" android:gravity="center_vertical">
            <Button android:id="@+id/btnBack" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="‹" android:textSize="20sp"
                android:background="@android:color/transparent" android:textColor="#9A9AA3"
                android:minWidth="0dp" android:minHeight="0dp" android:padding="8dp"
                android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Import Health Connect" android:textSize="18sp"
                android:textColor="#F4F4F6" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Instructions Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#141419"
            android:layout_margin="16dp" android:padding="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HOW TO EXPORT" android:textSize="9sp" android:textColor="#D9B96A"
                android:letterSpacing="0.14" android:layout_marginBottom="12dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="1" android:textSize="13sp" android:textColor="#A100FF"
                    android:textStyle="bold" android:gravity="center"
                    android:background="#1F0A33"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:text="Open Health Connect app on your device"
                    android:textSize="13sp" android:textColor="#9A9AA3"
                    android:gravity="center_vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="2" android:textSize="13sp" android:textColor="#A100FF"
                    android:textStyle="bold" android:gravity="center"
                    android:background="#1F0A33"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:text="Go to Settings → Data &amp; privacy"
                    android:textSize="13sp" android:textColor="#9A9AA3"
                    android:gravity="center_vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="3" android:textSize="13sp" android:textColor="#A100FF"
                    android:textStyle="bold" android:gravity="center"
                    android:background="#1F0A33"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:text="Tap Export or Backup data"
                    android:textSize="13sp" android:textColor="#9A9AA3"
                    android:gravity="center_vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="10dp">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="4" android:textSize="13sp" android:textColor="#A100FF"
                    android:textStyle="bold" android:gravity="center"
                    android:background="#1F0A33"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:text="Save the ZIP file to your device"
                    android:textSize="13sp" android:textColor="#9A9AA3"
                    android:gravity="center_vertical"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="28dp" android:layout_height="28dp"
                    android:text="5" android:textSize="13sp" android:textColor="#A100FF"
                    android:textStyle="bold" android:gravity="center"
                    android:background="#1F0A33"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:text="Tap the button below to import"
                    android:textSize="13sp" android:textColor="#9A9AA3"
                    android:gravity="center_vertical"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Select ZIP Button -->
        <Button android:id="@+id/btnSelectZip"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:text="Select Health Connect ZIP"
            android:textSize="14sp" android:textColor="#FFFFFF"
            android:background="#A100FF"/>

        <!-- Result -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#141419"
            android:layout_margin="16dp" android:padding="16dp">
            <TextView android:id="@+id/tvImportResult"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="No file imported yet."
                android:textSize="13sp" android:textColor="#5C5C66"
                android:lineSpacingMultiplier="1.5"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
