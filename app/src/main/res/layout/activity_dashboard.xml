<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0B">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="‹"
                    android:textSize="20sp"
                    android:background="@android:color/transparent"
                    android:textColor="#9A9AA3"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HEALTH ANALYTICS"
                    android:textSize="13sp"
                    android:textColor="#F4F4F6"
                    android:letterSpacing="0.08"
                    android:textStyle="bold"
                    android:paddingStart="8dp"/>

                <Button
                    android:id="@+id/btnAIAdvisory"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="AI Advisory"
                    android:textSize="11sp"
                    android:textColor="#C86BFF"
                    android:background="@drawable/bg_chip_inactive"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>
            </LinearLayout>

            <!-- Period tabs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp">

                <TextView android:id="@+id/tvTabDaily"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="DAILY" android:textSize="10sp" android:textColor="#A100FF"
                    android:letterSpacing="0.08" android:paddingBottom="6dp"/>

                <TextView android:id="@+id/tvTabWeekly"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="WEEKLY" android:textSize="10sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.08" android:paddingBottom="6dp"/>

                <TextView android:id="@+id/tvTabMonthly"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="MONTHLY" android:textSize="10sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.08" android:paddingBottom="6dp"/>

                <TextView android:id="@+id/tvTabYearly"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="YEARLY" android:textSize="10sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.08" android:paddingBottom="6dp"/>
            </LinearLayout>

            <!-- Health score and metrics -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#141419"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tvHealthScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="72"
                    android:textSize="56sp"
                    android:textColor="#F4F4F6"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvScoreLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good"
                    android:textSize="14sp"
                    android:textColor="#4FD1A0"
                    android:layout_marginBottom="4dp"/>

                <ProgressBar
                    android:id="@+id/pbScore"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:max="100"
                    android:progress="72"
                    android:progressDrawable="@drawable/progress_green"/>
            </LinearLayout>

            <!-- Metrics 2-row grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="4dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#141419" android:padding="12dp" android:layout_marginEnd="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="CALORIES" android:textSize="8sp" android:textColor="#5C5C66"
                        android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/tvCalVal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp" android:textColor="#C86BFF"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#141419" android:padding="12dp"
                    android:layout_marginStart="1dp" android:layout_marginEnd="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="STEPS" android:textSize="8sp" android:textColor="#5C5C66"
                        android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/tvStepsVal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp" android:textColor="#4FD1A0"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#141419" android:padding="12dp"
                    android:layout_marginStart="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SLEEP" android:textSize="8sp" android:textColor="#5C5C66"
                        android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/tvSleepVal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp" android:textColor="#D9B96A"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#141419" android:padding="12dp" android:layout_marginEnd="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="WATER" android:textSize="8sp" android:textColor="#5C5C66"
                        android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/tvWaterVal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp" android:textColor="#5C7AFF"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#141419" android:padding="12dp"
                    android:layout_marginStart="1dp" android:layout_marginEnd="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HEART RATE" android:textSize="8sp" android:textColor="#5C5C66"
                        android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/tvHRVal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp" android:textColor="#FF5C7A"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:background="#141419" android:padding="12dp"
                    android:layout_marginStart="1dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="EXERCISE" android:textSize="8sp" android:textColor="#5C5C66"
                        android:letterSpacing="0.1"/>
                    <TextView android:id="@+id/tvExerciseVal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="—" android:textSize="14sp" android:textColor="#C86BFF"
                        android:textStyle="bold" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Bar chart -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7-DAY CALORIE TREND"
                android:textSize="9sp"
                android:textColor="#5C5C66"
                android:letterSpacing="0.14"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:id="@+id/llBarChart"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:gravity="bottom"/>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#17FFFFFF"/>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#0A0A0B"
        app:menu="@menu/bottom_nav"
        app:itemTextColor="@color/bottom_nav_item_colors"
        app:itemIconTint="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"/>

</LinearLayout>
