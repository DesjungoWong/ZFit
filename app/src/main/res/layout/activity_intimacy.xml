<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A0B">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
      android:paddingTop="16dp" android:paddingBottom="10dp" android:gravity="center_vertical">
    <Button android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp"
        android:text="&#8249;" android:textSize="20sp" android:background="@android:color/transparent"
        android:textColor="#9A9AA3" android:minWidth="0dp" android:minHeight="0dp" android:padding="0dp"/>
    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:text="INTIMACY LOG" android:textSize="14sp"
        android:textColor="#F4F4F6" android:textStyle="bold" android:letterSpacing="0.06" android:paddingStart="8dp"/>
  </LinearLayout>
  <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="16dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="horizontal" android:layout_marginBottom="4dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="#141419" android:padding="16dp" android:layout_marginEnd="1dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="THIS MONTH" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
          <TextView android:id="@+id/tvMonthCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="0" android:textSize="36sp" android:textColor="#C86BFF" android:textStyle="bold"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="#141419" android:padding="16dp" android:layout_marginStart="1dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="LAST EVENT" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
          <TextView android:id="@+id/tvLastEvent" android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="--" android:textSize="18sp" android:textColor="#F4F4F6" android:textStyle="bold" android:layout_marginTop="6dp"/>
        </LinearLayout>
      </LinearLayout>
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="horizontal" android:layout_marginBottom="16dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="#141419" android:padding="16dp" android:layout_marginEnd="1dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="AVG / WEEK" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
          <TextView android:id="@+id/tvAvgWeek" android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="0.0 / week" android:textSize="16sp" android:textColor="#D9B96A" android:textStyle="bold" android:layout_marginTop="6dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="#141419" android:padding="16dp" android:layout_marginStart="1dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="STREAK" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
          <TextView android:id="@+id/tvStreak" android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:text="--" android:textSize="16sp" android:textColor="#4FD1A0" android:textStyle="bold" android:layout_marginTop="6dp"/>
        </LinearLayout>
      </LinearLayout>
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="horizontal" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnLogToday" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="LOG TODAY" android:textSize="13sp"
            android:textColor="#FFFFFF" android:letterSpacing="0.06" android:background="#A100FF"
            android:layout_marginEnd="6dp" android:minWidth="0dp" android:minHeight="0dp"/>
        <Button android:id="@+id/btnViewHistory" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="HISTORY" android:textSize="13sp"
            android:textColor="#9A9AA3" android:background="@drawable/bg_chip_inactive"
            android:minWidth="0dp" android:minHeight="0dp"/>
      </LinearLayout>
      <LinearLayout android:id="@+id/llHistory" android:layout_width="match_parent"
          android:layout_height="wrap_content" android:orientation="vertical"/>
    </LinearLayout>
  </ScrollView>
</LinearLayout>