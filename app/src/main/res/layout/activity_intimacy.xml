<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101013">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#0A0A0B"
            android:padding="16dp" android:gravity="center_vertical">
            <Button android:id="@+id/btnBack" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="‹" android:textSize="20sp"
                android:background="@android:color/transparent" android:textColor="#9A9AA3"
                android:minWidth="0dp" android:minHeight="0dp" android:padding="8dp"
                android:layout_marginEnd="8dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Intimacy Tracker" android:textSize="18sp"
                    android:textColor="#F4F4F6" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Private · stored locally only"
                    android:textSize="11sp" android:textColor="#5C5C66"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Stats Grid -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="16dp" android:paddingBottom="4dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#141419" android:padding="14dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="THIS MONTH" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvMonthCount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0"
                    android:textSize="28sp" android:textColor="#C86BFF" android:textStyle="bold"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#141419" android:padding="14dp" android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="LAST EVENT" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvLastEvent" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textSize="14sp" android:textColor="#F4F4F6"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#141419" android:padding="14dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AVG / WEEK" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvAvgWeek" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textSize="14sp" android:textColor="#F4F4F6"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#141419" android:padding="14dp" android:layout_marginStart="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="STREAK" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.1" android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvStreak" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textSize="14sp" android:textColor="#4FD1A0"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Log Button -->
        <Button android:id="@+id/btnLogToday"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            android:text="Log Today" android:textSize="15sp" android:textColor="#FFFFFF"
            android:background="#A100FF"/>

        <Button android:id="@+id/btnViewHistory"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:text="View History" android:textSize="13sp" android:textColor="#5C5C66"
            android:background="#141419"/>

        <!-- History List -->
        <LinearLayout android:id="@+id/llHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"/>

    </LinearLayout>
</ScrollView>
