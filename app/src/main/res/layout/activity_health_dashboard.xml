<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101013">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#0A0A0B"
            android:padding="16dp" android:gravity="center_vertical">
            <Button android:id="@+id/btnBack" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="‹" android:textSize="20sp"
                android:background="@android:color/transparent" android:textColor="#9A9AA3"
                android:minWidth="0dp" android:minHeight="0dp" android:padding="8dp"
                android:layout_marginEnd="8dp"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Health Overview"
                android:textSize="18sp" android:textColor="#F4F4F6" android:textStyle="bold"/>
            <Button android:id="@+id/btnLogHealth"
                android:layout_width="wrap_content" android:layout_height="32dp"
                android:text="Log Data" android:textSize="11sp" android:textColor="#A100FF"
                android:background="#1F0A33" android:paddingStart="10dp" android:paddingEnd="10dp"
                android:minWidth="0dp" android:minHeight="0dp"/>
        </LinearLayout>

        <!-- Date Nav -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp">
            <Button android:id="@+id/btnPrevDay" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="‹" android:textSize="20sp"
                android:background="@android:color/transparent" android:textColor="#9A9AA3"
                android:minWidth="0dp" android:minHeight="0dp" android:padding="8dp"/>
            <TextView android:id="@+id/tvDate" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="Today"
                android:textSize="14sp" android:textColor="#F4F4F6"/>
            <Button android:id="@+id/btnNextDay" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="›" android:textSize="20sp"
                android:background="@android:color/transparent" android:textColor="#9A9AA3"
                android:minWidth="0dp" android:minHeight="0dp" android:padding="8dp"/>
        </LinearLayout>

        <!-- Score -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#141419"
            android:layout_margin="16dp" android:padding="16dp" android:gravity="center_vertical">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DAILY HEALTH SCORE" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.12" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvHealthScore" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textSize="42sp" android:textColor="#F4F4F6" android:textStyle="bold"/>
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="/ 100" android:textSize="16sp" android:textColor="#5C5C66"/>
        </LinearLayout>

        <!-- Nutrition Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#141419"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="4dp" android:padding="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="NUTRITION" android:textSize="9sp" android:textColor="#D9B96A"
                android:letterSpacing="0.12" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Consumed" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvCalConsumed" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#C86BFF"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Burned" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvCalBurned" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#4FD1A0"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Net" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvCalNet" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#F4F4F6"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Sleep Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#141419"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="4dp" android:padding="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SLEEP" android:textSize="9sp" android:textColor="#5C7AFF"
                android:letterSpacing="0.12" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Score" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvSleepScore" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#5C7AFF"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Duration" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvSleepHours" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#5C7AFF"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Activity Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#141419"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="4dp" android:padding="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ACTIVITY" android:textSize="9sp" android:textColor="#4FD1A0"
                android:letterSpacing="0.12" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Steps" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvSteps" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#4FD1A0"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Exercise" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvExercise" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#E8A838"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Body Card -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#141419"
            android:layout_margin="16dp" android:padding="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BODY" android:textSize="9sp" android:textColor="#A100FF"
                android:letterSpacing="0.12" android:layout_marginBottom="10dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Heart Rate" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvHeartRate" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#FF5C7A"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Weight" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvWeight" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#F4F4F6"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Body Fat" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvBodyFat" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#F4F4F6"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Stress" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvStress" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#E8A838"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Water" android:textSize="10sp" android:textColor="#5C5C66"/>
                    <TextView android:id="@+id/tvWater" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="—"
                        android:textSize="15sp" android:textColor="#5C7AFF"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Button android:id="@+id/btnAIRating"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:text="Get AI Health Rating" android:textSize="14sp" android:textColor="#FFFFFF"
            android:background="#A100FF"/>

    </LinearLayout>
</ScrollView>
