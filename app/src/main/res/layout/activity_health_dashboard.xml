<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0B">
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingTop="16dp" android:paddingBottom="10dp" android:gravity="center_vertical">
          <Button android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp"
              android:text="&#8249;" android:textSize="20sp" android:background="@android:color/transparent"
              android:textColor="#9A9AA3" android:minWidth="0dp" android:minHeight="0dp" android:padding="0dp"/>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="8dp">
            <Button android:id="@+id/btnPrevDay" android:layout_width="32dp" android:layout_height="32dp"
                android:text="&#8249;" android:textSize="18sp" android:background="@android:color/transparent"
                android:textColor="#9A9AA3" android:minWidth="0dp" android:minHeight="0dp" android:padding="0dp"/>
            <TextView android:id="@+id/tvDate" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Today" android:textSize="13sp" android:textColor="#F4F4F6"
                android:paddingStart="4dp" android:paddingEnd="4dp"/>
            <Button android:id="@+id/btnNextDay" android:layout_width="32dp" android:layout_height="32dp"
                android:text="&#8250;" android:textSize="18sp" android:background="@android:color/transparent"
                android:textColor="#9A9AA3" android:minWidth="0dp" android:minHeight="0dp" android:padding="0dp"/>
          </LinearLayout>
          <Button android:id="@+id/btnLogHealth" android:layout_width="wrap_content" android:layout_height="32dp"
              android:text="Log" android:textSize="11sp" android:textColor="#A100FF"
              android:background="@drawable/bg_chip_active" android:paddingStart="12dp" android:paddingEnd="12dp"
              android:layout_marginEnd="6dp" android:minWidth="0dp" android:minHeight="0dp"/>
          <Button android:id="@+id/btnAIRating" android:layout_width="wrap_content" android:layout_height="32dp"
              android:text="AI" android:textSize="11sp" android:textColor="#C86BFF"
              android:background="@drawable/bg_chip_inactive" android:paddingStart="12dp" android:paddingEnd="12dp"
              android:minWidth="0dp" android:minHeight="0dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="#141419"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="4dp"
            android:padding="16dp" android:gravity="center_vertical">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HEALTH SCORE" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.12"/>
            <TextView android:id="@+id/tvHealthScore" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="42sp" android:textColor="#F4F4F6" android:textStyle="bold"/>
          </LinearLayout>
          <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
              android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/tvCalConsumed" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="-- kcal" android:textSize="13sp" android:textColor="#C86BFF" android:layout_marginBottom="2dp"/>
            <TextView android:id="@+id/tvCalBurned" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="-- burned" android:textSize="13sp" android:textColor="#4FD1A0" android:layout_marginBottom="2dp"/>
            <TextView android:id="@+id/tvCalNet" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="-- net" android:textSize="13sp" android:textColor="#9A9AA3"/>
          </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="4dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:background="#141419" android:padding="14dp" android:layout_marginEnd="1dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="STEPS" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvSteps" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="22sp" android:textColor="#4FD1A0" android:textStyle="bold" android:layout_marginTop="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="goal 10,000" android:textSize="9sp" android:textColor="#5C5C66" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:background="#141419" android:padding="14dp" android:layout_marginStart="1dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SLEEP" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvSleepHours" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="-- hrs" android:textSize="22sp" android:textColor="#D9B96A" android:textStyle="bold" android:layout_marginTop="4dp"/>
            <TextView android:id="@+id/tvSleepScore" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="quality --" android:textSize="9sp" android:textColor="#5C5C66" android:layout_marginTop="2dp"/>
          </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="4dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:background="#141419" android:padding="14dp" android:layout_marginEnd="1dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WEIGHT" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvWeight" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="-- kg" android:textSize="22sp" android:textColor="#F4F4F6" android:textStyle="bold" android:layout_marginTop="4dp"/>
            <TextView android:id="@+id/tvBodyFat" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="fat --" android:textSize="9sp" android:textColor="#5C5C66" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:background="#141419" android:padding="14dp" android:layout_marginStart="1dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="EXERCISE" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvExercise" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="-- min" android:textSize="22sp" android:textColor="#C86BFF" android:textStyle="bold" android:layout_marginTop="4dp"/>
            <TextView android:id="@+id/tvStress" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="stress --" android:textSize="9sp" android:textColor="#5C5C66" android:layout_marginTop="2dp"/>
          </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="16dp">
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:background="#141419" android:padding="12dp" android:layout_marginEnd="1dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="HEART RATE" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvHeartRate" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="18sp" android:textColor="#FF5C7A" android:textStyle="bold" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:background="#141419" android:padding="12dp" android:layout_marginStart="1dp" android:layout_marginEnd="1dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="WATER" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvWater" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="-- ml" android:textSize="18sp" android:textColor="#5C7AFF" android:textStyle="bold" android:layout_marginTop="2dp"/>
          </LinearLayout>
          <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
              android:layout_weight="1" android:orientation="vertical"
              android:background="#141419" android:padding="12dp" android:layout_marginStart="1dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BMI" android:textSize="8sp" android:textColor="#5C5C66" android:letterSpacing="0.1"/>
            <TextView android:id="@+id/tvBodyFatPct" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="--" android:textSize="18sp" android:textColor="#D9B96A" android:textStyle="bold" android:layout_marginTop="2dp"/>
          </LinearLayout>
        </LinearLayout>
      </LinearLayout>
    </ScrollView>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#17FFFFFF"/>
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav" android:layout_width="match_parent" android:layout_height="56dp"
        android:background="#0A0A0B" app:menu="@menu/bottom_nav"
        app:itemTextColor="@color/bottom_nav_item_colors" app:itemIconTint="@color/bottom_nav_item_colors"
        app:labelVisibilityMode="labeled"/>
</LinearLayout>