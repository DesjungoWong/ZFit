<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101013"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#0A0A0B"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DE.Fit"
                android:textSize="22sp"
                android:textColor="#F4F4F6"
                android:textStyle="bold"
                android:letterSpacing="0.06"/>

            <!-- Health Connected pill -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Health Connected"
                android:textSize="11sp"
                android:textColor="#4FD1A0"
                android:background="#141419"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="⚙"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:textColor="#5C5C66"
                android:padding="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"/>
        </LinearLayout>

        <!-- Date Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btnPrevDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹"
                android:textSize="20sp"
                android:background="@android:color/transparent"
                android:textColor="#9A9AA3"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="8dp"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Today"
                android:textSize="14sp"
                android:textColor="#F4F4F6"/>

            <Button
                android:id="@+id/btnNextDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textSize="20sp"
                android:background="@android:color/transparent"
                android:textColor="#9A9AA3"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="8dp"/>
        </LinearLayout>

        <!-- Calorie Ring Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#141419"
            android:layout_margin="16dp"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvCaloriesBig"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0 / 2000 kcal"
                android:textSize="32sp"
                android:textColor="#F4F4F6"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <ProgressBar
                android:id="@+id/pbCalorie"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_purple"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvRemaining" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Remaining\n0"
                        android:textSize="13sp" android:textColor="#9A9AA3" android:gravity="center"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp" android:background="#1A1A20"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvBurned" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Burned\n0"
                        android:textSize="13sp" android:textColor="#9A9AA3" android:gravity="center"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="32dp" android:background="#1A1A20"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/tvNet" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Net\n0"
                        android:textSize="13sp" android:textColor="#9A9AA3" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Macros Panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">

            <!-- Protein -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#141419" android:padding="12dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PROTEIN" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.12" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvProteinVal" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0g"
                    android:textSize="18sp" android:textColor="#5C7AFF" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvProteinPct" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0%"
                    android:textSize="10sp" android:textColor="#5C5C66" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/pbProtein" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="3dp"
                    android:max="100" android:progressDrawable="@drawable/progress_blue"/>
            </LinearLayout>

            <!-- Carbs -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#141419" android:padding="12dp"
                android:layout_marginStart="4dp" android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CARBS" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.12" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvCarbsVal" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0g"
                    android:textSize="18sp" android:textColor="#D9B96A" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvCarbsPct" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0%"
                    android:textSize="10sp" android:textColor="#5C5C66" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/pbCarbs" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="3dp"
                    android:max="100" android:progressDrawable="@drawable/progress_purple"/>
            </LinearLayout>

            <!-- Fat -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="#141419" android:padding="12dp" android:layout_marginStart="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FAT" android:textSize="9sp" android:textColor="#5C5C66"
                    android:letterSpacing="0.12" android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvFatVal" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0g"
                    android:textSize="18sp" android:textColor="#C86BFF" android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvFatPct" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0%"
                    android:textSize="10sp" android:textColor="#5C5C66" android:layout_marginBottom="4dp"/>
                <ProgressBar android:id="@+id/pbFat" style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent" android:layout_height="3dp"
                    android:max="100" android:progressDrawable="@drawable/progress_purple"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Water Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#141419"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:padding="14dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💧" android:textSize="18sp" android:layout_marginEnd="10dp"/>

            <TextView android:id="@+id/tvWaterVal"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="0 ml"
                android:textSize="16sp" android:textColor="#5C7AFF"/>

            <Button android:id="@+id/btnWater200"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="+200ml" android:textSize="12sp" android:textColor="#5C7AFF"
                android:background="@drawable/bg_chip_inactive"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:layout_marginEnd="6dp"
                android:minWidth="0dp" android:minHeight="0dp"/>

            <Button android:id="@+id/btnWater500"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="+500ml" android:textSize="12sp" android:textColor="#5C7AFF"
                android:background="@drawable/bg_chip_inactive"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:minWidth="0dp" android:minHeight="0dp"/>
        </LinearLayout>

        <!-- 6-Button Action Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="4dp">

                <Button android:id="@+id/btnAddFood"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:text="Add Food" android:textSize="12sp" android:textColor="#F4F4F6"
                    android:background="@drawable/bg_action_button" android:layout_marginEnd="4dp"
                    android:minWidth="0dp" android:minHeight="0dp"/>

                <Button android:id="@+id/btnSnapLog"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:text="Snap &amp; Log" android:textSize="12sp" android:textColor="#F4F4F6"
                    android:background="@drawable/bg_action_button" android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:minWidth="0dp" android:minHeight="0dp"/>

                <Button android:id="@+id/btnDashboard"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:text="Dashboard" android:textSize="12sp" android:textColor="#F4F4F6"
                    android:background="@drawable/bg_action_button" android:layout_marginStart="4dp"
                    android:minWidth="0dp" android:minHeight="0dp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button android:id="@+id/btnHCImport"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:text="HC Import" android:textSize="12sp" android:textColor="#F4F4F6"
                    android:background="@drawable/bg_action_button" android:layout_marginEnd="4dp"
                    android:minWidth="0dp" android:minHeight="0dp"/>

                <Button android:id="@+id/btnHealthOverview"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:text="Health" android:textSize="12sp" android:textColor="#F4F4F6"
                    android:background="@drawable/bg_action_button" android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:minWidth="0dp" android:minHeight="0dp"/>

                <Button android:id="@+id/btnWeeklyReport"
                    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                    android:text="Weekly" android:textSize="12sp" android:textColor="#F4F4F6"
                    android:background="@drawable/bg_action_button" android:layout_marginStart="4dp"
                    android:minWidth="0dp" android:minHeight="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Intimacy quick access -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">
            <Button android:id="@+id/btnIntimacy"
                android:layout_width="match_parent" android:layout_height="40dp"
                android:text="Intimacy Tracker" android:textSize="12sp" android:textColor="#5C5C66"
                android:background="@drawable/bg_chip_inactive"
                android:minWidth="0dp" android:minHeight="0dp"/>
        </LinearLayout>

        <!-- Section: Food Log -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="TODAY'S LOG" android:textSize="10sp" android:textColor="#5C5C66"
            android:letterSpacing="0.16" android:paddingStart="16dp" android:paddingEnd="16dp"
            android:paddingBottom="8dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvFoodLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:nestedScrollingEnabled="false"/>

        <!-- FAB area -->
        <Button
            android:id="@+id/btnAddFoodFab"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:text="+ Log Food"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:background="#A100FF"/>

    </LinearLayout>
</ScrollView>
