<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DEFit" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/colorBg2</item>
        <item name="android:statusBarColor">@color/colorBg</item>
        <item name="android:navigationBarColor">@color/colorBg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/colorPurple</item>
        <item name="colorPrimaryDark">@color/colorBg</item>
        <item name="colorAccent">@color/colorPurple</item>
        <item name="android:textColorPrimary">@color/colorTxt</item>
        <item name="android:textColorSecondary">@color/colorMut</item>
    </style>

    <style name="Widget.DEFit.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/colorPurple</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.DEFit.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="strokeColor">@color/colorLine</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/colorDim</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <style name="Widget.DEFit.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabTextColor">@color/colorDim</item>
        <item name="tabSelectedTextColor">@color/colorPurple</item>
        <item name="tabIndicatorColor">@color/colorPurple</item>
        <item name="tabIndicatorHeight">2dp</item>
    </style>

    <style name="Widget.DEFit.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/colorMut</item>
        <item name="chipBackgroundColor">@color/colorPanel</item>
        <item name="chipStrokeColor">@color/colorLine</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">2dp</item>
        <item name="checkedIconEnabled">false</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>
